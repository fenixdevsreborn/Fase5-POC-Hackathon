<nav class="cs-nav @(Mobile ? "cs-nav--mobile" : string.Empty)" aria-label="Navegacao principal">
    @* Todos os destinos sao reais: as entradas de pagina usam NavLink (destacam a rota ativa) e
       apontam para @@page existentes; as ancoras levam a secoes que existem na landing (/#id). *@
    <NavLink href="/" Match="NavLinkMatch.All" @onclick="NotifyNavigate">Início</NavLink>
    <a href="/#como-funciona" @onclick="NotifyNavigate">Como funciona</a>
    <NavLink href="/campanhas" Match="NavLinkMatch.Prefix" @onclick="NotifyNavigate">Campanhas</NavLink>
    <a href="/#instituicoes" @onclick="NotifyNavigate">Instituicoes</a>
    <a href="/#impacto" @onclick="NotifyNavigate">Impacto</a>
    <NavLink href="/transparencia" Match="NavLinkMatch.Prefix" @onclick="NotifyNavigate">Transparencia</NavLink>

    <AuthorizeView Roles="Doador">
        <NavLink class="cs-nav__private" href="/doador" Match="NavLinkMatch.All" @onclick="NotifyNavigate">
            Meu painel
        </NavLink>
        <NavLink class="cs-nav__private" href="/doador/doacoes" Match="NavLinkMatch.Prefix" @onclick="NotifyNavigate">
            Minhas doacoes
        </NavLink>
    </AuthorizeView>

    <AuthorizeView Roles="GestorONG">
        <NavLink class="cs-nav__private" href="/gestor" Match="NavLinkMatch.All" @onclick="NotifyNavigate">
            Painel gestor
        </NavLink>
        <NavLink class="cs-nav__private" href="/gestor/campanhas/nova" Match="NavLinkMatch.Prefix" @onclick="NotifyNavigate">
            Nova campanha
        </NavLink>
    </AuthorizeView>
</nav>

@code {
    [Parameter] public bool Mobile { get; set; }
    [Parameter] public EventCallback OnNavigate { get; set; }

    private Task NotifyNavigate() => OnNavigate.InvokeAsync();
}
