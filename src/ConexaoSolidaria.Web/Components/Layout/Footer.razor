<footer class="cs-footer">
    <div class="cs-footer__shell">
        <section class="cs-footer__cta" aria-labelledby="footer-cta-title">
            <div>
                <span class="cs-footer__eyebrow">Juntos, podemos mais</span>
                <h2 id="footer-cta-title">Uma contribuicao pode iniciar uma grande transformacao.</h2>
            </div>
            <div class="cs-footer__cta-actions">
                <a class="cs-footer__button cs-footer__button--primary" href="/campanhas">
                    <MudIcon Icon="@Icons.Material.Filled.FavoriteBorder" Size="Size.Small" />
                    Apoiar uma causa
                </a>
                <a class="cs-footer__button cs-footer__button--secondary" href="/cadastrar">
                    Criar campanha
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                </a>
            </div>
        </section>

        <div class="cs-footer__content">
            <div class="cs-footer__identity">
                <a class="cs-footer__logo" href="/" aria-label="Conexao Solidaria - pagina inicial">
                    <img src="images/logo/logomarca-horizontal.png" alt="Conexao Solidaria" />
                </a>
                <p>
                    Aproximamos pessoas e instituicoes por meio de campanhas seguras,
                    transparentes e orientadas a impacto real.
                </p>
                <div class="cs-footer__trust" aria-label="Compromissos da plataforma">
                    <span><MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" /> Seguranca</span>
                    <span><MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" /> Transparencia</span>
                </div>
            </div>

            <nav class="cs-footer__column" aria-labelledby="footer-plataforma-title">
                <h3 id="footer-plataforma-title">Plataforma</h3>
                <a href="/campanhas">Campanhas</a>
                <a href="/transparencia">Transparencia</a>
                <a href="/#como-funciona">Como funciona</a>
                <a href="/#instituicoes">Para instituicoes</a>
            </nav>

            <nav class="cs-footer__column" aria-labelledby="footer-acesso-title">
                <h3 id="footer-acesso-title">Acesso rapido</h3>
                <a href="/entrar">Entrar</a>
                <a href="/cadastrar">Criar conta</a>
                <a href="/status">Status dos servicos</a>
                <a href="/#sobre">Sobre o projeto</a>
            </nav>
        </div>

        <div class="cs-footer__bottom">
            <span>&copy; @DateTime.UtcNow.Year Conexao Solidaria. Todos os direitos reservados.</span>
            <span class="cs-footer__project">
                <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Small" />
                Projeto desenvolvido para o FIAP Hackathon
            </span>
        </div>
    </div>
</footer>
