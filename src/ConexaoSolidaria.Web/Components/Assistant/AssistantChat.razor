@* Chat do Assistente Solidario (IA), estilo ChatGPT. O estado da conversa vive no
   AssistantChatService (scoped por circuito); este componente so renderiza e faz o
   throttle do streaming. *@
@using ConexaoSolidaria.Web.Services.Ai
@using Microsoft.AspNetCore.Components.Web
@implements IDisposable
@inject AssistantChatService Chat

<div class="cs-chat d-flex flex-column">
    @* column-reverse mantem o scroll ancorado no fim durante o streaming (sem JS). *@
    <div class="cs-chat__scroll" style="display:flex; flex-direction:column-reverse">
        <div class="cs-chat__thread">
            @if (Chat.Mensagens.Count == 0)
            {
                <div class="cs-chat__welcome">
                    <div class="cs-chat__welcome-avatar">
                        <MudIcon Icon="@Icons.Material.Filled.SmartToy" />
                    </div>
                    <h3>Ola! Sou o Assistente Solidario</h3>
                    <p>Posso buscar campanhas, mostrar quanto cada uma arrecadou e consultar suas doacoes.</p>

                    <div class="cs-chat__suggestions">
                        @foreach (var s in Sugestoes)
                        {
                            <button type="button" class="cs-chat__suggestion"
                                    disabled="@Chat.Ocupado"
                                    @onclick="@(() => EnviarTextoAsync(s.Texto))">
                                <MudIcon Icon="@s.Icone" Size="Size.Small" />
                                <span>@s.Texto</span>
                            </button>
                        }
                    </div>
                </div>
            }

            @foreach (var msg in Chat.Mensagens)
            {
                var doUsuario = msg.Role == "user";
                <div class="cs-msg @(doUsuario ? "cs-msg--user" : "cs-msg--bot")">
                    <div class="cs-msg__avatar">
                        <MudIcon Icon="@(doUsuario ? Icons.Material.Filled.Person : Icons.Material.Filled.SmartToy)" Size="Size.Small" />
                    </div>
                    @if (!doUsuario && string.IsNullOrEmpty(msg.Text) && Chat.Ocupado)
                    {
                        <div class="cs-msg__bubble cs-typing">
                            <span></span><span></span><span></span>
                        </div>
                    }
                    else
                    {
                        <div class="cs-msg__bubble @(msg.IsError ? "cs-msg__bubble--error" : string.Empty)">@msg.Text</div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="cs-chat__composer">
        <MudTextField T="string"
                      @bind-Value="_texto"
                      Placeholder="Pergunte sobre campanhas ou doacoes..."
                      Variant="Variant.Text"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Underline="false"
                      Disabled="@Chat.Ocupado"
                      OnKeyDown="OnKeyDown"
                      Style="flex:1" />
        <button type="button" class="cs-chat__send"
                disabled="@(Chat.Ocupado || string.IsNullOrWhiteSpace(_texto))"
                @onclick="EnviarAsync"
                aria-label="Enviar mensagem">
            <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" />
        </button>
    </div>
</div>

@code {
    private readonly CancellationTokenSource _cts = new();
    private string _texto = string.Empty;
    private long _ultimoRender;

    private static readonly (string Texto, string Icone)[] Sugestoes =
    {
        ("Quais campanhas estao ativas?", Icons.Material.Filled.Campaign),
        ("Campanhas de saude e educacao", Icons.Material.Filled.Favorite),
        ("Quais ja bateram a meta?", Icons.Material.Filled.EmojiEvents),
        ("Ver minhas doacoes", Icons.Material.Filled.VolunteerActivism),
    };

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await EnviarAsync();
        }
    }

    private Task EnviarAsync() => EnviarTextoAsync(_texto);

    private async Task EnviarTextoAsync(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto) || Chat.Ocupado)
        {
            return;
        }

        _texto = string.Empty;
        // Throttle de ~100ms nos chunks para nao inundar o circuito SignalR;
        // a chamada final (Ocupado=false) sempre renderiza.
        await Chat.EnviarAsync(texto, onUpdate: async () =>
        {
            var agora = Environment.TickCount64;
            if (Chat.Ocupado && agora - _ultimoRender < 100)
            {
                return;
            }

            _ultimoRender = agora;
            await InvokeAsync(StateHasChanged);
        }, _cts.Token);
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
