@* KPI de negócio reutilizável do painel do gestor. *@

<MudPaper Elevation="0" Class="cs-kpi-card" data-reveal>
    <div class="cs-kpi-card__inner">
        <MudAvatar Color="Cor" Variant="Variant.Filled" Rounded="true" Size="Size.Large" Class="cs-kpi-card__icon">
            <MudIcon Icon="@Icone" />
        </MudAvatar>
        <div class="cs-kpi-card__content">
            <span>@Titulo</span>
            <strong>@Valor</strong>
        </div>
    </div>
</MudPaper>

@code {
    [Parameter] public string Titulo { get; set; } = string.Empty;
    [Parameter] public string Valor { get; set; } = string.Empty;
    [Parameter] public string Icone { get; set; } = Icons.Material.Filled.Insights;
    [Parameter] public Color Cor { get; set; } = Color.Primary;
}
