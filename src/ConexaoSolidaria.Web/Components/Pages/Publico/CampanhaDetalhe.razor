@page "/campanhas/{Id}"
@using System.Globalization
@using ConexaoSolidaria.Web.Components.Campaigns
@using ConexaoSolidaria.Web.Components.Common
@using ConexaoSolidaria.Web.Components.Donations
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>@(_campanha?.Titulo ?? "Campanha")</PageTitle>

@if (_carregando)
{
    <LoadingSkeleton Count="2" />
}
else if (_erroCarregar)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-4">
        Nao foi possivel carregar a campanha agora.
        <MudButton Size="Size.Small" Class="ml-2" OnClick="CarregarAsync">Tentar novamente</MudButton>
    </MudAlert>
}
else if (_campanha is null)
{
    <EmptyState Icon="@Icons.Material.Filled.SearchOff" Title="Campanha não encontrada" Description="Ela pode ter sido encerrada ou o endereço informado está incorreto.">
        <MudButton Href="/campanhas" Variant="Variant.Filled" Color="Color.Primary">Ver campanhas</MudButton>
    </EmptyState>
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="cs-breadcrumbs px-0 pt-0 pb-3" />

    <header class="campaign-detail-hero" data-reveal>
        <img class="campaign-detail-hero__image" src="@CampaignVisuals.ImagemDe(_campanha.Id)" alt="@_campanha.Titulo" />
        <div class="campaign-detail-hero__shade"></div>
        <div class="campaign-detail-hero__content">
            <div class="campaign-detail-hero__tags">
                <span><MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />@CampaignVisuals.RotuloCategoria(_campanha.Categoria)</span>
                <span class="campaign-detail-hero__status campaign-detail-hero__status--@_campanha.Status.ToLowerInvariant()">@StatusRotulo</span>
            </div>
            <h1>@_campanha.Titulo</h1>
            <p>Uma campanha transparente, criada para transformar solidariedade em impacto real.</p>
            <div class="campaign-detail-hero__facts">
                <span><MudIcon Icon="@Icons.Material.Filled.Groups" /><strong>@DoadoresLabel</strong><small>participando</small></span>
                <span><MudIcon Icon="@Icons.Material.Filled.Schedule" /><strong>@DiasLabel</strong><small>para contribuir</small></span>
                <span><MudIcon Icon="@Icons.Material.Filled.VerifiedUser" /><strong>Verificada</strong><small>pela plataforma</small></span>
            </div>
        </div>
    </header>

    <MudGrid Spacing="4" Class="campaign-detail-content">
        <MudItem xs="12" md="7">
            <section class="campaign-story cs-panel" data-reveal>
                <span class="cs-kicker">Conheça a causa</span>
                <h2>Sobre esta campanha</h2>
                <p class="campaign-story__description">@_campanha.Descricao</p>

                <div class="campaign-story__period">
                    <span class="cs-icon-orb"><MudIcon Icon="@Icons.Material.Filled.CalendarMonth" /></span>
                    <div><small>Período da campanha</small><strong>@_campanha.DataInicio.ToLocalTime().ToString("dd MMM yyyy", Br) — @_campanha.DataFim.ToLocalTime().ToString("dd MMM yyyy", Br)</strong></div>
                </div>
            </section>

            <section class="campaign-trust" data-reveal aria-label="Compromissos da campanha">
                <article><MudIcon Icon="@Icons.Material.Filled.Visibility" /><div><strong>Transparência</strong><span>Progresso público e atualizado.</span></div></article>
                <article><MudIcon Icon="@Icons.Material.Filled.Security" /><div><strong>Segurança</strong><span>Processamento protegido.</span></div></article>
                <article><MudIcon Icon="@Icons.Material.Filled.TrackChanges" /><div><strong>Rastreabilidade</strong><span>Acompanhamento por protocolo.</span></div></article>
            </section>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Elevation="0" Class="campaign-donation-card pa-5" data-reveal>
                <span class="cs-kicker">Progresso da causa</span>
                <MudText Typo="Typo.h4" Color="Color.Primary" Class="campaign-donation-card__value">@_campanha.ValorTotalArrecadado.ToString("C", Br)</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                    arrecadados de @_campanha.MetaFinanceira.ToString("C", Br)
                </MudText>

                <MudProgressLinear Color="Color.Success"
                                   Value="_percentual"
                                   Max="100"
                                   Size="Size.Large"
                                   Rounded="true"
                                   Class="my-2" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @_percentual.ToString("0.#", Br)% da meta atingida
                </MudText>

                <MudDivider Class="my-4" />

                @if (!_podeDoar)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                        Esta campanha não está aberta para doações no momento.
                    </MudAlert>
                }
                else if (_doacaoId is Guid doacao)
                {
                    <DonationStatus DoacaoId="doacao" />
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-2"
                               OnClick="@(() => _doacaoId = null)">
                        Fazer outra doacao
                    </MudButton>
                }
                else
                {
                    <AuthorizeView Roles="Doador">
                        <Authorized>
                            @if (_mostrarForm)
                            {
                                <DonationForm CampanhaId="_campanha.Id"
                                              OnDonationAccepted="OnDoacaoAceita"
                                              OnCancel="@(() => _mostrarForm = false)" />
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                           Size="Size.Large"
                                           StartIcon="@Icons.Material.Filled.VolunteerActivism"
                                           OnClick="@(() => _mostrarForm = true)">
                                    Doar agora
                                </MudButton>
                            }
                        </Authorized>
                        <NotAuthorized>
                            <AuthorizeView Context="anon">
                                <Authorized>
                                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                        Apenas contas de doador podem realizar doações.
                                    </MudAlert>
                                </Authorized>
                                <NotAuthorized>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                               Size="Size.Large"
                                               StartIcon="@Icons.Material.Filled.Login"
                                               Href="@EntrarParaDoarHref">
                                        Entrar para doar
                                    </MudButton>
                                </NotAuthorized>
                            </AuthorizeView>
                        </NotAuthorized>
                    </AuthorizeView>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private static readonly CultureInfo Br = new("pt-BR");

    [Parameter]
    public string? Id { get; set; }

    private CampanhaDto? _campanha;
    private bool _carregando = true;
    private bool _erroCarregar;
    private bool _mostrarForm;
    private Guid? _doacaoId;

    private double _percentual;
    private int _diasRestantes;
    private bool _podeDoar;
    private List<BreadcrumbItem> _breadcrumbs = new();

    private Color StatusCor => _campanha?.Status switch
    {
        "Ativa" => Color.Success,
        "Encerrada" => Color.Default,
        _ => Color.Warning,
    };

    private string StatusRotulo => _campanha?.Status == "Concluida" ? "Concluída" : _campanha?.Status ?? string.Empty;
    private string DoadoresLabel => (_campanha?.TotalDoadores ?? 0) switch { 0 => "Seja o primeiro", 1 => "1 doador", var total => $"{total:N0} doadores" };
    private string DiasLabel => _diasRestantes switch { <= 0 => "Encerrada", 1 => "Último dia", var dias => $"{dias} dias" };

    private string EntrarParaDoarHref =>
        $"/entrar?returnUrl={Uri.EscapeDataString($"/campanhas/{Id}")}";

    protected override async Task OnParametersSetAsync()
    {
        await CarregarAsync();
    }

    private async Task CarregarAsync()
    {
        _carregando = true;
        _erroCarregar = false;
        _campanha = null;
        _doacaoId = null;
        _mostrarForm = false;

        try
        {
            if (!Guid.TryParse(Id, out var campanhaId))
            {
                return; // cai no estado "nao encontrada"
            }

            // GET /api/campanhas/{id} agora e publico (AllowAnonymous): busca direta
            // por Id, sem o over-fetch de 100 campanhas do modelo anterior.
            _campanha = await Api.ObterCampanhaAsync(campanhaId);

            if (_campanha is not null)
            {
                CalcularDerivados();
                _breadcrumbs = new()
                {
                    new BreadcrumbItem("Campanhas", "/campanhas"),
                    new BreadcrumbItem(_campanha.Titulo, null, disabled: true),
                };
            }
        }
        catch (Exception)
        {
            _erroCarregar = true;
        }
        finally
        {
            _carregando = false;
        }
    }

    private void CalcularDerivados()
    {
        if (_campanha is null)
        {
            return;
        }

        _percentual = _campanha.MetaFinanceira > 0
            ? Math.Clamp((double)(_campanha.ValorTotalArrecadado / _campanha.MetaFinanceira) * 100d, 0d, 100d)
            : 0d;

        var restantes = (_campanha.DataFim - DateTimeOffset.Now).TotalDays;
        _diasRestantes = restantes > 0 ? (int)Math.Ceiling(restantes) : 0;

        _podeDoar = string.Equals(_campanha.Status, "Ativa", StringComparison.OrdinalIgnoreCase)
                    && _campanha.DataFim > DateTimeOffset.Now;
    }

    private void OnDoacaoAceita(Guid doacaoId)
    {
        _doacaoId = doacaoId;
        _mostrarForm = false;
        StateHasChanged();
    }
}
