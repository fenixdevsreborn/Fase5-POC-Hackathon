@page "/campanhas"
@using ConexaoSolidaria.Web.Components.Common
@using ConexaoSolidaria.Web.Components.Campaigns
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Campanhas - Conexão Solidária</PageTitle>

<section class="campaign-page">
    <header class="cs-page-header">
        <div class="cs-page-header__content">
            <span class="cs-page-header__badge">
                <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Small" />
                Faça parte dessa conexão
            </span>
            <h1 class="cs-page-header__title">Campanhas que <span>transformam vidas</span></h1>
            <p class="cs-page-header__lead">Explore campanhas ativas e escolha onde você quer fazer a diferença. Sua contribuição pode mudar o amanhã de alguém.</p>
        </div>
    </header>

    @if (!_loading && !_error && _campanhas.Count > 0)
    {
        <div class="campaign-stats" aria-label="Resumo das campanhas exibidas">
            <div class="campaign-stat">
                <span class="campaign-stat__icon campaign-stat__icon--blue"><MudIcon Icon="@Icons.Material.Filled.Campaign" /></span>
                <span><small>Campanhas encontradas</small><strong>@_total</strong></span>
            </div>
            <div class="campaign-stat">
                <span class="campaign-stat__icon campaign-stat__icon--orange"><MudIcon Icon="@Icons.Material.Filled.Paid" /></span>
                <span><small>Arrecadado nesta página</small><strong>@Money(TotalArrecadado)</strong></span>
            </div>
            <div class="campaign-stat">
                <span class="campaign-stat__icon campaign-stat__icon--blue"><MudIcon Icon="@Icons.Material.Filled.Groups" /></span>
                <span><small>Doadores nesta página</small><strong>@TotalDoadores.ToString("N0", Ptbr)</strong></span>
            </div>
        </div>
    }

    <div class="campaign-search">
        <MudAutocomplete T="CampanhaDto"
                         Value="_selecionada"
                         ValueChanged="OnSugestaoSelecionada"
                         SearchFunc="BuscarSugestoesAsync"
                         ToStringFunc="@(c => c?.Titulo ?? string.Empty)"
                         DebounceInterval="350"
                         MinCharacters="0"
                         ResetValueOnEmptyText="true"
                         CoerceText="false"
                         Clearable="true"
                         OnClearButtonClick="OnClear"
                         MaxItems="6"
                         Placeholder="Busque por titulo, causa ou categoria..."
                         Variant="Variant.Outlined"
                         Margin="Margin.Dense"
                         Adornment="Adornment.Start"
                         AdornmentIcon="@Icons.Material.Filled.Search"
                         Class="campaign-search__field">
            <ItemTemplate Context="sugestao">
                <div class="campaign-suggestion">
                    <img class="campaign-suggestion__thumb"
                         src="@CampaignVisuals.ImagemDe(sugestao.Id)" alt="" loading="lazy" />
                    <span class="campaign-suggestion__text">
                        <strong>@sugestao.Titulo</strong>
                        <small>@CampaignVisuals.RotuloCategoria(sugestao.Categoria) · @Money(sugestao.ValorTotalArrecadado) arrecadados</small>
                    </span>
                    <MudIcon Icon="@Icons.Material.Filled.NorthEast" Size="Size.Small" Class="campaign-suggestion__go" />
                </div>
            </ItemTemplate>
            <NoItemsTemplate>
                <div class="campaign-suggestion campaign-suggestion--empty">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Small" />
                    <span>Nenhuma sugestao — veja os resultados abaixo.</span>
                </div>
            </NoItemsTemplate>
        </MudAutocomplete>
        <span class="campaign-search__hint">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
            Busca inteligente: tolera erros de digitacao e sugere enquanto voce escreve.
        </span>
    </div>

    @if (_loading)
    {
        <LoadingSkeleton Count="6" />
    }
    else if (_error)
    {
        <EmptyState Icon="@Icons.Material.Filled.CloudOff"
                    Title="Não foi possível carregar as campanhas"
                    Description="Ocorreu um erro ao falar com o servidor. Tente novamente em instantes.">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="Recarregar">
                Tentar novamente
            </MudButton>
        </EmptyState>
    }
    else if (_campanhas.Count == 0)
    {
        <EmptyState Icon="@Icons.Material.Filled.SearchOff"
                    Title="Nenhuma campanha encontrada"
                    Description="@(string.IsNullOrWhiteSpace(_query)
                        ? "Ainda não há campanhas cadastradas."
                        : $"Não encontramos resultados para \"{_query}\". Tente outros termos.")" />
    }
    else
    {
        <div class="campaign-results__heading">
            <div>
                <span>CAUSAS EM DESTAQUE</span>
                <h2>Escolha como transformar</h2>
            </div>
            <p>@_total campanha(s) encontrada(s)</p>
        </div>

        <div class="campaign-grid">
            @foreach (var campanha in _campanhas)
            {
                <CampaignCard @key="campanha.Id" Campanha="campanha" Horizontal="true" />
            }
        </div>

        @if (_totalPages > 1)
        {
            <div class="campaign-pagination">
                <MudPagination Color="Color.Primary" Count="_totalPages" Selected="_page"
                               SelectedChanged="OnPageChanged" Rectangular="true"
                               ShowFirstButton="true" ShowLastButton="true" />
            </div>
        }
    }
</section>

@code {
    private const int PageSize = 8;
    private static readonly System.Globalization.CultureInfo Ptbr = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");
    private string _query = string.Empty;
    private CampanhaDto? _selecionada;
    private int _page = 1;
    private int _total;
    private int _totalPages;
    private bool _loading = true;
    private bool _error;
    private IReadOnlyList<CampanhaDto> _campanhas = Array.Empty<CampanhaDto>();
    private decimal TotalArrecadado => _campanhas.Sum(x => x.ValorTotalArrecadado);
    private int TotalDoadores => _campanhas.Sum(x => x.TotalDoadores);

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = false; StateHasChanged();
        try
        {
            var result = await Api.BuscarCampanhasAsync(_query, _page, PageSize);
            _campanhas = result.Items; _total = result.Total; _totalPages = result.TotalPages;
            if (_page > _totalPages && _totalPages > 0) { _page = _totalPages; await LoadAsync(); return; }
        }
        catch { _error = true; _campanhas = Array.Empty<CampanhaDto>(); }
        finally { _loading = false; StateHasChanged(); }
    }

    // Chamado pelo MudAutocomplete a cada digitacao (com debounce). Filtra a grade E devolve
    // as melhores sugestoes (predicao) para o dropdown — a busca fuzzy roda no backend.
    private async Task<IEnumerable<CampanhaDto>> BuscarSugestoesAsync(string? value, CancellationToken ct)
    {
        var termo = value ?? string.Empty;
        if (!string.Equals(termo, _query, StringComparison.Ordinal))
        {
            _query = termo;
            _page = 1;
            await LoadAsync();
        }

        return string.IsNullOrWhiteSpace(termo)
            ? Array.Empty<CampanhaDto>()
            : _campanhas.Take(6);
    }

    // Selecionar uma sugestao (predicao) leva direto para a campanha.
    private void OnSugestaoSelecionada(CampanhaDto? campanha)
    {
        _selecionada = campanha;
        if (campanha is not null)
        {
            Nav.NavigateTo($"/campanhas/{campanha.Id}");
        }
    }

    private Task OnClear() { _query = string.Empty; _selecionada = null; _page = 1; return LoadAsync(); }
    private Task OnPageChanged(int page) { _page = page; return LoadAsync(); }
    private Task Recarregar() => LoadAsync();
    private static string Money(decimal value) => value.ToString("C0", Ptbr);
}
