@page "/"
@using System.Globalization
@using ConexaoSolidaria.Web.Components.Common
@using ConexaoSolidaria.Web.Components.Campaigns
@implements IAsyncDisposable
@inject ApiClient Api
@inject IJSRuntime JS

<PageTitle>Conexão Solidária - Doe com transparência</PageTitle>

@* =====================================================================================
   Experiência cinematográfica "O Laço": sequência de quadros no canvas dirigida pelo
   scroll (js/cinematic.js). Os textos sobrepostos são HTML real; a logomarca é camada
   HTML (nunca IA). Sem JS ou com prefers-reduced-motion, tudo renderiza como seções
   empilhadas estáticas — nenhum conteúdo depende do canvas.
   IMPORTANTE (diff Blazor x GSAP): as camadas .cine-overlay são marcação estática — o
   JS controla o style delas; dados dinâmicos ficam apenas em <span> internos.
   ===================================================================================== *@
<div class="cine-wrap" id="cine-wrap">
    <section class="cine-stage" id="cine-stage" aria-label="A jornada de uma doação">
        <canvas class="cine-canvas" aria-hidden="true"></canvas>
        <div class="cine-veil" aria-hidden="true"></div>

        <img class="cine-logo cine-logo--screen" src="images/logo/logomarca.webp"
             alt="" aria-hidden="true" />

        @* ---- Clipe 1 · Hero ---- *@
        <div class="cine-overlay cine-o1">
            <h1 class="cine-title">
                Conectamos quem quer <span class="cine-accent-blue">ajudar</span><br />
                com quem <span class="cine-accent-orange">precisa.</span>
            </h1>
            <p class="cine-lead">
                Uma plataforma segura e transparente para doações, campanhas e projetos
                que transformam vidas e fortalecem comunidades.
            </p>
            <div class="cine-actions">
                <a class="cine-btn cine-btn--primary" href="/campanhas">Quero Doar</a>
                <a class="cine-btn cine-btn--ghost" href="/cadastrar">Criar Campanha</a>
            </div>
            <span class="cine-scrollhint" aria-hidden="true">Role para acompanhar a jornada</span>
        </div>

        @* ---- Clipe 2 · A máquina que não perde uma doação ---- *@
        <div class="cine-overlay cine-o2">
            <span class="cine-kicker">Por trás da tela</span>
            <h2 class="cine-h2">Sua doação viaja em segurança.</h2>
            <ul class="cine-pillars">
                <li><strong>Nenhuma doação se perde</strong><span>registro transacional de ponta a ponta</span></li>
                <li><strong>Processada exatamente uma vez</strong><span>proteção contra duplicidade</span></li>
                <li><strong>Acompanhamento em tempo real</strong><span>você vê cada etapa acontecer</span></li>
            </ul>
            <div class="cine-trust">
                <span>100% Seguro</span><span>Transparência</span><span>Impacto Real</span>
            </div>
        </div>

        @* ---- Clipe 3 · Como funciona ---- *@
        <div class="cine-overlay cine-o3">
            <span class="cine-kicker">Simples e transparente</span>
            <h2 class="cine-h2">Como funciona</h2>
            <ol class="cine-steps">
                <li><strong>1. Escolha uma causa</strong><span>Explore as campanhas ativas e encontre a que mais combina com você.</span></li>
                <li><strong>2. Faça sua doação</strong><span>Contribua com o valor que quiser, de forma rápida e segura.</span></li>
                <li><strong>3. Acompanhe o impacto</strong><span>Veja em tempo real o quanto cada campanha já arrecadou.</span></li>
            </ol>
        </div>

        @* ---- Clipe 4 · Impacto + instituições ---- *@
        <div class="cine-overlay cine-o4">
            <span class="cine-kicker">Impacto real</span>
            <div class="cine-stats">
                <div class="cine-stat">
                    <span class="cine-stat__value">@_totalArrecadado.ToString("C0", Ptbr)</span>
                    <span class="cine-stat__label">Total arrecadado</span>
                </div>
                <div class="cine-stat">
                    <span class="cine-stat__value">@_campanhasAtivas.ToString("N0", Ptbr)</span>
                    <span class="cine-stat__label">Campanhas ativas</span>
                </div>
                <div class="cine-stat">
                    <span class="cine-stat__value">@_totalCampanhas.ToString("N0", Ptbr)</span>
                    <span class="cine-stat__label">Campanhas no total</span>
                </div>
            </div>
            <h2 class="cine-h2">Sua instituição pode ampliar o impacto.</h2>
            <p class="cine-lead cine-lead--small">
                Crie campanhas, acompanhe resultados e mostre cada etapa da arrecadação
                com transparência.
            </p>
            <a class="cine-btn cine-btn--ghost" href="/cadastrar">Criar campanha</a>
        </div>

        @* ---- Clipe 5 · O laço fecha ---- *@
        <div class="cine-overlay cine-o5 cine-final">
            <div class="cine-final__logo-area" aria-hidden="true">
                <span class="cine-particle"></span><span class="cine-particle"></span>
                <span class="cine-particle"></span><span class="cine-particle"></span>
                <span class="cine-particle"></span><span class="cine-particle"></span>
                <span class="cine-particle"></span><span class="cine-particle"></span>
                <span class="cine-particle"></span><span class="cine-particle"></span>
                <img class="cine-logo cine-logo--final" src="images/logo/logomarca.webp" alt="" />
            </div>
            <h2 class="cine-h2">Tecnologia a serviço da solidariedade.</h2>
            <p class="cine-lead cine-lead--small">
                Aproximamos quem quer ajudar de projetos confiáveis, com segurança e
                visibilidade sobre cada contribuição.
            </p>
            <figure class="cine-campaign">
                <img src="images/campanhas/web/medium-shot-mother-girl-home.jpg"
                     alt="Campanha real: mãe e filha em casa" loading="lazy" />
                <figcaption>Cada doação recomeça o ciclo.</figcaption>
            </figure>
            <div class="cine-actions">
                <a class="cine-btn cine-btn--primary" href="/campanhas">Quero Doar</a>
                <a class="cine-btn cine-btn--ghost" href="/transparencia">Ver transparência</a>
            </div>
        </div>
    </section>

    @* Alvos de âncora (footer aponta para /#como-funciona etc.). Posicionados por
       porcentagem do wrapper — funcionam no modo cinematográfico e no estático. *@
    <span id="como-funciona" class="cine-anchor" style="top:39%" aria-hidden="true"></span>
    <span id="impacto" class="cine-anchor" style="top:58%" aria-hidden="true"></span>
    <span id="instituicoes" class="cine-anchor" style="top:66%" aria-hidden="true"></span>
    <span id="sobre" class="cine-anchor" style="top:86%" aria-hidden="true"></span>
</div>

@* ---------------- Campanhas em destaque (fluxo normal, dados vivos) ---------------- *@
<section class="cs-section" aria-labelledby="campanhas-title">
    <div class="cs-section__heading">
        <div>
            <span class="cs-section__eyebrow">Causas que transformam</span>
            <h2 id="campanhas-title">Campanhas em destaque</h2>
        </div>
        <MudButton Href="/campanhas" Variant="Variant.Text" Color="Color.Primary"
                   EndIcon="@Icons.Material.Filled.ArrowForward" Class="d-none d-sm-flex">
            Ver todas
        </MudButton>
    </div>

    @if (_loading)
    {
        <LoadingSkeleton Count="3" />
    }
    else if (_destaques.Count == 0)
    {
        <EmptyState Icon="@Icons.Material.Filled.Campaign"
                    Title="Nenhuma campanha ativa no momento"
                    Description="Assim que novas campanhas forem publicadas, elas aparecerão aqui." />
    }
    else
    {
        <MudGrid>
            @foreach (var campanha in _destaques)
            {
                <MudItem @key="campanha.Id" xs="12" sm="6" md="4">
                    <CampaignCard Campanha="campanha" />
                </MudItem>
            }
        </MudGrid>
    }
</section>

@code {
    private static readonly CultureInfo Ptbr = CultureInfo.GetCultureInfo("pt-BR");

    private bool _loading = true;
    private decimal _totalArrecadado;
    private int _campanhasAtivas;
    private int _totalCampanhas;
    private IReadOnlyList<CampanhaDto> _destaques = Array.Empty<CampanhaDto>();

    private IJSObjectReference? _module;
    private IJSObjectReference? _scene;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        // A cena não depende de dados: inicializa primeiro, para o primeiro paint ser
        // imediato mesmo com o Gateway lento/fora (o prerender não bloqueia mais na API).
        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/cinematic.js");
            _scene = await _module.InvokeAsync<IJSObjectReference?>("init", "cine-stage");
        }
        catch (JSException)
        {
            // Sem módulo/quadros a landing continua funcional no modo estático.
        }

        await CarregarDadosAsync();
        StateHasChanged();
    }

    private async Task CarregarDadosAsync()
    {
        try
        {
            var transparencia = await Api.TransparenciaAsync();
            var campanhas = await Api.BuscarCampanhasAsync(null, 1, 3);

            _totalArrecadado = transparencia.Sum(t => t.ValorTotalArrecadado);
            _campanhasAtivas = transparencia.Count;
            _totalCampanhas = campanhas.Total;
            _destaques = campanhas.Items
                .Where(c => c.Status == "Ativa")
                .Take(3)
                .ToList();
        }
        catch
        {
            // Falha de rede: a experiência cinematográfica e o conteúdo estático seguem.
            _destaques = Array.Empty<CampanhaDto>();
        }
        finally
        {
            _loading = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_scene is not null)
            {
                await _scene.InvokeVoidAsync("destroy");
                await _scene.DisposeAsync();
            }

            if (_module is not null)
            {
                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuito encerrado (navegação/refresh): o browser já descartou tudo.
        }
    }
}
