@page "/gestor/campanhas/{Id}/editar"
@using ConexaoSolidaria.Web.Components.Campaigns
@inject ApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Editar campanha</PageTitle>

<AuthorizeView Roles="GestorONG">
    <Authorized>
        <header class="cs-page-header">
            <div class="cs-page-header__content">
                <span class="cs-page-header__badge">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    Ajustar detalhes
                </span>
                <h1 class="cs-page-header__title">Editar <span>Campanha</span></h1>
                <p class="cs-page-header__lead">
                    Atualize os dados da sua campanha abaixo. As alterações serão salvas e validadas pela plataforma.
                </p>
            </div>
        </header>

        @if (_carregando)
        {
            <div class="cs-loading-state"><MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" /></div>
        }
        else if (_naoEncontrada)
        {
            <MudAlert Severity="Severity.Warning" Class="my-4">
                Campanha não encontrada.
                <MudLink Href="/gestor">Voltar ao painel</MudLink>
            </MudAlert>
        }
        else
        {
            <div class="edit-campaign-layout">
                <section class="edit-campaign-card" data-reveal>
                    <div class="edit-campaign-card__head">
                        <span class="edit-campaign-card__step"><MudIcon Icon="@Icons.Material.Filled.EditNote" /></span>
                        <div><h2>Informações da campanha</h2><p>Revise os campos antes de salvar. As alterações aparecem na vitrine pública.</p></div>
                    </div>
                    <CampaignForm Model="_model" SubmitLabel="Salvar alterações" OnSubmit="SalvarAsync" ErrorMessage="@_erro" />
                </section>
                <aside class="edit-campaign-side cs-panel cs-panel--soft" data-reveal>
                    <span class="cs-icon-orb cs-icon-orb--green"><MudIcon Icon="@Icons.Material.Filled.TipsAndUpdates" /></span>
                    <h2>Antes de publicar</h2>
                    <p>Dados claros aumentam a confiança e ajudam o doador a entender o impacto esperado.</p>
                    <ul>
                        <li><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />Título direto e específico</li>
                        <li><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />Meta compatível com o objetivo</li>
                        <li><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />Descrição transparente</li>
                        <li><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />Prazo realista</li>
                    </ul>
                    <a class="cs-action-link" href="/gestor">Voltar ao painel</a>
                </aside>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <section class="cs-access-state"><div>
            <span class="cs-access-state__icon"><MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Large" /></span>
            <h1>Área de gestão protegida</h1><p>Entre como gestor para editar esta campanha.</p>
            <MudButton Href="/entrar" Variant="Variant.Filled" Color="Color.Primary">Entrar</MudButton>
        </div></section>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter] public string? Id { get; set; }

    private bool _carregando = true;
    private bool _naoEncontrada;
    private Guid _campanhaId;
    private SalvarCampanha? _model;
    private string? _erro;

    protected override async Task OnInitializedAsync()
    {
        if (!Guid.TryParse(Id, out _campanhaId))
        {
            _naoEncontrada = true;
            _carregando = false;
            return;
        }

        try
        {
            var campanha = await Api.ObterCampanhaAsync(_campanhaId);
            if (campanha is null)
            {
                _naoEncontrada = true;
            }
            else
            {
                _model = new SalvarCampanha(
                    Titulo: campanha.Titulo,
                    Descricao: campanha.Descricao,
                    DataInicio: campanha.DataInicio,
                    DataFim: campanha.DataFim,
                    MetaFinanceira: campanha.MetaFinanceira,
                    Status: campanha.Status,
                    Categoria: campanha.Categoria);
            }
        }
        catch
        {
            _naoEncontrada = true;
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task SalvarAsync(SalvarCampanha dto)
    {
        _erro = null;
        try
        {
            var atualizada = await Api.AtualizarCampanhaAsync(_campanhaId, dto);
            if (atualizada is null)
            {
                _erro = "Não foi possível salvar (verifique meta>0 e datas).";
                return;
            }

            Snackbar.Add("Campanha atualizada com sucesso.", Severity.Success);
            Nav.NavigateTo("/gestor");
        }
        catch
        {
            _erro = "Ocorreu um erro inesperado ao salvar a campanha. Tente novamente.";
        }
    }
}
