@page "/gestor/campanhas/nova"
@using System.Globalization
@using ConexaoSolidaria.Web.Components.Campaigns
@using ConexaoSolidaria.Web.Services.Ai
@inject ApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject CampaignDraftService Rascunho

<PageTitle>Nova campanha</PageTitle>

<AuthorizeView Roles="GestorONG">
    <Authorized>
      <div class="cs-page-shell">
        <header class="cs-page-header cs-page-header--plain">
            <div class="cs-page-header__content">
                <h1 class="cs-page-header__title">Nova <span>Campanha</span></h1>
                <p class="cs-page-header__lead">
                    Monte quantas campanhas quiser e salve todas de uma vez. Escolha um dos caminhos abaixo:
                    preencher à mão, gerar com IA ou importar uma planilha.
                </p>
            </div>
        </header>

        <div class="nova-campanha" data-reveal>
            <section class="nc-metodos" aria-label="Como criar campanhas">
                <button type="button" class="nc-metodo nc-metodo--blue" @onclick="CriarManualAsync">
                    <span class="nc-metodo__ico"><MudIcon Icon="@Icons.Material.Rounded.DriveFileRenameOutline" /></span>
                    <span class="nc-metodo__txt">
                        <strong>Criar manualmente</strong>
                        <small>Preencha os dados da campanha em um formulário.</small>
                    </span>
                    <MudIcon Icon="@Icons.Material.Rounded.Add" Class="nc-metodo__go" />
                </button>

                @if (Rascunho.Enabled)
                {
                    <button type="button" class="nc-metodo nc-metodo--violet" @onclick="CriarComIaAsync">
                        <span class="nc-metodo__ico"><MudIcon Icon="@Icons.Material.Rounded.AutoAwesome" /></span>
                        <span class="nc-metodo__txt">
                            <strong>Criar com IA</strong>
                            <small>Descreva a ideia e receba rascunhos prontos.</small>
                        </span>
                        <MudIcon Icon="@Icons.Material.Rounded.Add" Class="nc-metodo__go" />
                    </button>
                }

                <button type="button" class="nc-metodo nc-metodo--teal" @onclick="ImportarPlanilhaAsync">
                    <span class="nc-metodo__ico"><MudIcon Icon="@Icons.Material.Rounded.TableChart" /></span>
                    <span class="nc-metodo__txt">
                        <strong>Importar planilha</strong>
                        <small>Traga várias campanhas de um Excel ou CSV.</small>
                    </span>
                    <MudIcon Icon="@Icons.Material.Rounded.Add" Class="nc-metodo__go" />
                </button>
            </section>

            @if (!string.IsNullOrWhiteSpace(_erro))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-2">@_erro</MudAlert>
            }

            @if (_lote.Count == 0)
            {
                <div class="nc-vazio">
                    <span class="nc-vazio__ico"><MudIcon Icon="@Icons.Material.Outlined.PlaylistAdd" /></span>
                    <h2>Nenhuma campanha na lista ainda</h2>
                    <p>Use um dos botões acima para montar sua primeira campanha. Você revisa tudo aqui antes de salvar.</p>
                </div>
            }
            else
            {
                <div class="nova-campanha__card nova-campanha__lote">
                    <div class="nova-campanha__card-head">
                        <span class="nova-campanha__step nova-campanha__step--ok">@_lote.Count</span>
                        <div>
                            <h2>Campanhas prontas para salvar</h2>
                            <p>Revise a lista antes de criar. Nada foi salvo ainda.</p>
                        </div>
                    </div>

                    <ul class="nova-campanha__lista">
                        @foreach (var item in _lote)
                        {
                            <li class="nova-campanha__item @(item.Erro is not null ? "nova-campanha__item--erro" : "")"
                                @key="item.Id">
                                <div class="nova-campanha__item-foto">
                                    @if (ApiClient.UrlImagemCampanha(item.Campanha.Imagem) is { } foto)
                                    {
                                        <img src="@foto" alt="" loading="lazy" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Image" />
                                    }
                                </div>

                                <div class="nova-campanha__item-dados">
                                    <strong>@item.Campanha.Titulo</strong>
                                    <span class="nova-campanha__item-meta">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">
                                            @CampaignVisuals.RotuloCategoria(item.Campanha.Categoria)
                                        </MudChip>
                                        @item.Campanha.MetaFinanceira.ToString("C2", Br)
                                        &middot;
                                        até @item.Campanha.DataFim.ToString("dd/MM/yyyy")
                                    </span>

                                    @if (item.Erro is not null)
                                    {
                                        <span class="nova-campanha__item-erro">
                                            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" />
                                            @item.Erro
                                        </span>
                                    }
                                </div>

                                <div class="nova-campanha__item-acoes">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Size="Size.Small"
                                                   aria-label="Editar campanha da lista"
                                                   Disabled="_salvando"
                                                   OnClick="@(() => EditarItemAsync(item))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   aria-label="Remover campanha da lista"
                                                   Disabled="_salvando"
                                                   OnClick="@(() => RemoverItem(item))" />
                                </div>
                            </li>
                        }
                    </ul>

                    <div class="nova-campanha__lote-acoes">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   Disabled="_salvando"
                                   OnClick="LimparLote">
                            Limpar lista
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Disabled="_salvando"
                                   OnClick="SalvarLoteAsync">
                            @if (_salvando)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Criar @_lote.Count campanha@(_lote.Count == 1 ? "" : "s")
                        </MudButton>
                    </div>
                </div>
            }
        </div>
      </div>
    </Authorized>
    <NotAuthorized>
        <section class="cs-access-state"><div>
            <span class="cs-access-state__icon"><MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Large" /></span>
            <h1>Área de gestão protegida</h1><p>Entre com o perfil de gestor para criar uma nova campanha.</p>
            <MudButton Href="/entrar?returnUrl=%2Fgestor%2Fcampanhas%2Fnova" Variant="Variant.Filled" Color="Color.Primary">Entrar</MudButton>
        </div></section>
    </NotAuthorized>
</AuthorizeView>

@code {
    private static readonly CultureInfo Br = CultureInfo.GetCultureInfo("pt-BR");

    /// <summary>
    /// Campanha aguardando salvamento. O Id local existe só para dar @key estável à lista
    /// (o Id real só nasce no backend) e o Erro guarda o motivo devolvido pelo lote.
    /// </summary>
    private sealed record ItemDoLote(Guid Id, SalvarCampanha Campanha, string? Erro = null);

    private readonly List<ItemDoLote> _lote = [];
    private string? _erro;
    private bool _salvando;

    private static SalvarCampanha FormularioVazio() => new(
        Titulo: string.Empty,
        Descricao: string.Empty,
        DataInicio: DateTimeOffset.Now,
        DataFim: DateTimeOffset.Now.AddDays(30),
        MetaFinanceira: 0m,
        Status: "Ativa",
        Categoria: "Saude");

    // ---------- Botões / dialogs ----------

    private Task CriarManualAsync() => AbrirFormAsync(
        FormularioVazio(),
        "Nova campanha",
        "Adicionar à lista",
        Icons.Material.Filled.PlaylistAdd,
        Icons.Material.Rounded.DriveFileRenameOutline,
        editandoId: null);

    private Task EditarItemAsync(ItemDoLote item) => AbrirFormAsync(
        item.Campanha,
        "Editar campanha",
        "Salvar alteração",
        Icons.Material.Filled.Check,
        Icons.Material.Rounded.Edit,
        editandoId: item.Id);

    private async Task AbrirFormAsync(
        SalvarCampanha model,
        string heading,
        string submitLabel,
        string submitIcon,
        string icon,
        Guid? editandoId)
    {
        _erro = null;

        var parametros = new DialogParameters<CampaignFormDialog>
        {
            { x => x.Model, model },
            { x => x.Heading, heading },
            { x => x.SubmitLabel, submitLabel },
            { x => x.SubmitIcon, submitIcon },
            { x => x.Icon, icon },
            { x => x.Validar, (Func<SalvarCampanha, string?>)(dto => ValidarTituloUnico(dto, editandoId)) },
        };

        var opcoes = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<CampaignFormDialog>(heading, parametros, opcoes);
        var resultado = await dialog.Result;

        if (resultado is null || resultado.Canceled || resultado.Data is not SalvarCampanha dto)
        {
            return;
        }

        if (editandoId is { } id)
        {
            var posicao = _lote.FindIndex(item => item.Id == id);
            if (posicao >= 0)
            {
                _lote[posicao] = _lote[posicao] with { Campanha = dto, Erro = null };
            }

            Snackbar.Add("Campanha atualizada na lista.", Severity.Success);
        }
        else
        {
            _lote.Add(new ItemDoLote(Guid.NewGuid(), dto));
            Snackbar.Add("Campanha adicionada. Continue ou salve a lista.", Severity.Success);
        }

        StateHasChanged();
    }

    private async Task CriarComIaAsync()
    {
        if (!Rascunho.Enabled)
        {
            return;
        }

        _erro = null;
        var opcoes = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<GerarComIaDialog>("Criar com IA", opcoes);
        var resultado = await dialog.Result;

        if (resultado is null || resultado.Canceled || resultado.Data is not IReadOnlyList<SalvarCampanha> geradas)
        {
            return;
        }

        var adicionadas = AdicionarVarias(geradas);
        Snackbar.Add(
            adicionadas == geradas.Count
                ? $"{adicionadas} campanha(s) adicionada(s) à lista. Revise antes de salvar."
                : $"{adicionadas} campanha(s) adicionada(s); as repetidas foram descartadas.",
            Severity.Success);
        StateHasChanged();
    }

    private async Task ImportarPlanilhaAsync()
    {
        _erro = null;
        var opcoes = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<ImportarPlanilhaDialog>("Importar planilha", opcoes);
        var resultado = await dialog.Result;

        if (resultado is null || resultado.Canceled || resultado.Data is not IReadOnlyList<SalvarCampanha> campanhas)
        {
            return;
        }

        var adicionadas = AdicionarVarias(campanhas);
        Snackbar.Add(
            adicionadas == campanhas.Count
                ? $"{adicionadas} campanha(s) importada(s). Revise antes de salvar."
                : $"{adicionadas} importada(s); as de título repetido foram descartadas.",
            Severity.Success);
        StateHasChanged();
    }

    // ---------- Lista (lote) ----------

    private void RemoverItem(ItemDoLote item) => _lote.RemoveAll(atual => atual.Id == item.Id);

    private void LimparLote() => _lote.Clear();

    // Barra o duplicado já na tela: a API também recusa, mas avisar aqui evita o gestor
    // montar dez campanhas e só descobrir o conflito ao salvar. Ignora o item em edição.
    private string? ValidarTituloUnico(SalvarCampanha dto, Guid? ignorarId)
    {
        var conflito = _lote.FirstOrDefault(item =>
            item.Id != ignorarId &&
            string.Equals(
                NormalizarTitulo(item.Campanha.Titulo),
                NormalizarTitulo(dto.Titulo),
                StringComparison.Ordinal));

        return conflito is not null
            ? $"Já existe uma campanha com o título \"{dto.Titulo}\" nesta lista."
            : null;
    }

    private async Task SalvarLoteAsync()
    {
        if (_lote.Count == 0)
        {
            return;
        }

        _salvando = true;
        _erro = null;

        try
        {
            var resultado = await Api.CriarCampanhasEmLoteAsync(_lote.Select(item => item.Campanha).ToList());
            if (resultado is null)
            {
                _erro = "Não foi possível salvar agora. Verifique sua conexão e tente novamente.";
                return;
            }

            // Sucesso parcial: as criadas somem da tela e as recusadas ficam com o motivo,
            // na mesma ordem em que foram enviadas (o backend devolve o índice do item).
            if (resultado.Erros.Count > 0)
            {
                var porIndice = resultado.Erros.ToDictionary(erro => erro.Indice, erro => erro.Motivo);

                var restantes = _lote
                    .Select((item, indice) => porIndice.TryGetValue(indice, out var motivo)
                        ? item with { Erro = motivo }
                        : null)
                    .Where(item => item is not null)
                    .Select(item => item!)
                    .ToList();

                _lote.Clear();
                _lote.AddRange(restantes);

                Snackbar.Add(
                    $"{resultado.Criadas.Count} criada(s), {resultado.Erros.Count} com problema. Corrija e salve de novo.",
                    Severity.Warning);
                return;
            }

            Snackbar.Add(
                $"{resultado.Criadas.Count} campanha(s) criada(s) com sucesso.", Severity.Success);
            _lote.Clear();
            Nav.NavigateTo("/gestor");
        }
        catch
        {
            _erro = "Ocorreu um erro inesperado ao criar as campanhas. Tente novamente.";
        }
        finally
        {
            _salvando = false;
        }
    }

    // Insere na lista descartando o que colidiria por título (com a lista atual ou entre si).
    private int AdicionarVarias(IEnumerable<SalvarCampanha> campanhas)
    {
        var existentes = _lote
            .Select(item => NormalizarTitulo(item.Campanha.Titulo))
            .ToHashSet(StringComparer.Ordinal);

        var adicionadas = 0;

        foreach (var campanha in campanhas)
        {
            if (!existentes.Add(NormalizarTitulo(campanha.Titulo)))
            {
                continue;
            }

            _lote.Add(new ItemDoLote(Guid.NewGuid(), campanha));
            adicionadas++;
        }

        return adicionadas;
    }

    /// <summary>
    /// Mesma normalização do backend (Campaign.NormalizarTitulo): trim, espaços internos
    /// colapsados e minúsculas. Duplicada aqui de propósito — a Web não referencia o projeto
    /// de domínio, e o servidor continua sendo a autoridade sobre a unicidade.
    /// </summary>
    private static string NormalizarTitulo(string? titulo)
    {
        if (string.IsNullOrWhiteSpace(titulo))
        {
            return string.Empty;
        }

        var partes = titulo.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries);
        return string.Join(' ', partes).ToLowerInvariant();
    }
}
