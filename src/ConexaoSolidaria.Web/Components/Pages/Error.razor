@page "/Error"
@using System.Diagnostics

<PageTitle>Algo não saiu como esperado</PageTitle>

<section class="error-page" data-reveal>
    <div class="error-page__content">
        <span class="cs-kicker">Erro inesperado</span>
        <h1>A conexão encontrou<br /><span>um obstáculo.</span></h1>
        <p>Não conseguimos concluir esta ação agora. Seus dados continuam protegidos e você pode tentar novamente com segurança.</p>
        <div class="error-page__actions">
            <a class="error-page__primary" href="."><MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" />Tentar novamente</a>
            <a class="error-page__secondary" href="/">Voltar ao início</a>
        </div>
        @if (ShowRequestId)
        {
            <span class="error-page__protocol">Protocolo técnico: <code>@RequestId</code></span>
        }
    </div>
    <div class="error-page__visual" aria-hidden="true">
        <span class="error-page__orbit error-page__orbit--one"></span>
        <span class="error-page__orbit error-page__orbit--two"></span>
        <span class="error-page__node error-page__node--one"></span>
        <span class="error-page__node error-page__node--two"></span>
        <span class="error-page__heart"><MudIcon Icon="@Icons.Material.Filled.HeartBroken" /></span>
    </div>
</section>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }
    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);
    protected override void OnInitialized() => RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
