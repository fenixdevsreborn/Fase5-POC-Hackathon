@page "/doador/doacoes/{Id}"
@using ConexaoSolidaria.Web.Components.Donations

<PageTitle>Acompanhar doação</PageTitle>

<AuthorizeView Roles="Doador">
    <Authorized>
        <MudBreadcrumbs Items="_breadcrumbs" Class="cs-breadcrumbs px-0" />
        <header class="cs-page-header">
            <div class="cs-page-header__content">
                <span class="cs-page-header__badge"><MudIcon Icon="@Icons.Material.Filled.TrackChanges" Size="Size.Small" />Acompanhamento ao vivo</span>
                <h1 class="cs-page-header__title">Sua doação, <span>etapa por etapa</span></h1>
                <p class="cs-page-header__lead">Acompanhe o processamento assíncrono e receba o comprovante assim que a contribuição for concluída.</p>
            </div>
        </header>

        @if (_doacaoId is Guid id)
        {
            <div class="donation-detail-grid">
                <section class="donation-detail-grid__status" data-reveal><DonationStatus DoacaoId="id" /></section>
                <aside class="donation-detail-help cs-panel cs-panel--soft" data-reveal>
                    <span class="cs-icon-orb"><MudIcon Icon="@Icons.Material.Filled.Security" /></span>
                    <h2>Processamento protegido</h2>
                    <p>Você pode sair desta página sem perder o acompanhamento. Guarde o protocolo para consultar novamente.</p>
                    <ul>
                        <li><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" /><span>Atualização automática</span></li>
                        <li><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" /><span>Sem cobrança em caso de rejeição</span></li>
                        <li><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" /><span>Comprovante ao concluir</span></li>
                    </ul>
                    <a class="cs-action-link" href="/doador/doacoes">Ver todas as doações <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" /></a>
                </aside>
            </div>
        }
        else
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="my-4">
                ID de doação inválido. Verifique o endereço e tente novamente.
                <MudButton Href="/doador" Size="Size.Small" Class="ml-2">Voltar ao painel</MudButton>
            </MudAlert>
        }
    </Authorized>
    <NotAuthorized>
        <section class="cs-access-state"><div>
            <span class="cs-access-state__icon"><MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" /></span>
            <h1>Acompanhamento protegido</h1>
            <p>Entre como doador para consultar o andamento desta contribuição.</p>
            <MudButton Href="@EntrarHref" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Login">Entrar</MudButton>
        </div></section>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public string? Id { get; set; }

    private Guid? _doacaoId;
    private List<BreadcrumbItem> _breadcrumbs = new();

    private string EntrarHref =>
        $"/entrar?returnUrl={Uri.EscapeDataString($"/doador/doacoes/{Id}")}";

    protected override void OnParametersSet()
    {
        _doacaoId = Guid.TryParse(Id, out var id) ? id : null;
        _breadcrumbs = new()
        {
            new BreadcrumbItem("Meu painel", "/doador"),
            new BreadcrumbItem("Doação", null, disabled: true),
        };
    }
}
