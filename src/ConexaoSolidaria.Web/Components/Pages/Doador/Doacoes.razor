@page "/doador/doacoes"
@using System.Globalization
@using ConexaoSolidaria.Web.Components.Common
@inject ApiClient Api

<PageTitle>Minhas doações</PageTitle>

<AuthorizeView Roles="Doador">
    <Authorized>
        <MudBreadcrumbs Items="_breadcrumbs" Class="cs-breadcrumbs px-0" />
        <header class="cs-page-header">
            <div class="cs-page-header__content">
                <span class="cs-page-header__badge">
                    <MudIcon Icon="@Icons.Material.Filled.VolunteerActivism" Size="Size.Small" />
                    Minhas Doações
                </span>
                <h1 class="cs-page-header__title">Histórico de <span>Contribuições</span></h1>
                <p class="cs-page-header__lead">
                    Acompanhe o status e o processamento de cada doação enviada às ONGs de forma transparente.
                </p>
            </div>
            <div class="cs-page-header__actions">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="CarregarAsync"
                           Disabled="_carregando">
                    Atualizar
                </MudButton>
            </div>
        </header>

        @if (_carregando)
        {
            <div class="cs-loading-state"><MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" /></div>
        }
        else if (_erro)
        {
            <MudAlert Severity="Severity.Error" Class="my-4">
                Nao foi possivel carregar suas doacoes.
                <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="CarregarAsync">Tentar novamente</MudButton>
            </MudAlert>
        }
        else if (_doacoes.Count == 0)
        {
            <EmptyState Icon="@Icons.Material.Filled.VolunteerActivism"
                        Title="Voce ainda nao fez doacoes"
                        Description="Explore as campanhas ativas e faca sua primeira doacao.">
                <MudButton Href="/campanhas" Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search">
                    Ver campanhas
                </MudButton>
            </EmptyState>
        }
        else
        {
            <section class="donations-summary" aria-label="Resumo das doações" data-reveal>
                <article><span class="donations-summary__icon"><MudIcon Icon="@Icons.Material.Filled.Savings" /></span><div><small>Total contribuído</small><strong>@FormatMoeda(TotalDoado)</strong></div></article>
                <article><span class="donations-summary__icon donations-summary__icon--green"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" /></span><div><small>Processadas</small><strong>@TotalProcessadas</strong></div></article>
                <article><span class="donations-summary__icon donations-summary__icon--orange"><MudIcon Icon="@Icons.Material.Filled.Schedule" /></span><div><small>Em acompanhamento</small><strong>@TotalPendentes</strong></div></article>
            </section>

            <div class="cs-section-heading" data-reveal>
                <div><span class="cs-kicker">Histórico completo</span><h2>Suas contribuições</h2></div>
                <p>Selecione uma doação para acompanhar cada etapa e acessar o comprovante após o processamento.</p>
            </div>

            <div class="cs-data-shell" data-reveal>
                <MudTable Items="_doacoes" Hover="true" Breakpoint="Breakpoint.Sm" Class="pa-2">
                    <HeaderContent>
                        <MudTh>Campanha</MudTh>
                        <MudTh Style="text-align:right">Valor</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Data</MudTh>
                        <MudTh Style="text-align:right">Acoes</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="row">
                        <MudTd DataLabel="Campanha">
                            <MudLink Href="@($"/campanhas/{row.CampanhaId}")">@row.CampanhaTitulo</MudLink>
                        </MudTd>
                        <MudTd DataLabel="Valor" Style="text-align:right">@FormatMoeda(row.ValorDoacao)</MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                     Color="@StatusCor(row.Status)">@StatusRotulo(row.Status)</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Data">@FormatData(row.CriadaEm)</MudTd>
                        <MudTd DataLabel="Acoes" Style="text-align:right">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       EndIcon="@Icons.Material.Filled.ArrowForward"
                                       Href="@($"/doador/doacoes/{row.DoacaoId}")">
                                Acompanhar
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <section class="cs-access-state"><div>
            <span class="cs-access-state__icon"><MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" /></span>
            <h1>Histórico protegido</h1>
            <p>Entre com sua conta de doador para consultar suas contribuições.</p>
            <MudButton Href="/entrar?returnUrl=%2Fdoador%2Fdoacoes" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Login">Entrar</MudButton>
        </div></section>
    </NotAuthorized>
</AuthorizeView>

@code {
    private static readonly CultureInfo Br = CultureInfo.GetCultureInfo("pt-BR");

    private bool _carregando = true;
    private bool _erro;
    private IReadOnlyList<MinhaDoacaoDto> _doacoes = Array.Empty<MinhaDoacaoDto>();
    private decimal TotalDoado => _doacoes.Where(d => d.Status == "Processada").Sum(d => d.ValorDoacao);
    private int TotalProcessadas => _doacoes.Count(d => d.Status == "Processada");
    private int TotalPendentes => _doacoes.Count(d => d.Status == "Pendente");

    private readonly List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Meu painel", "/doador"),
        new BreadcrumbItem("Minhas doações", null, disabled: true),
    };

    protected override async Task OnInitializedAsync() => await CarregarAsync();

    private async Task CarregarAsync()
    {
        _carregando = true;
        _erro = false;
        try
        {
            _doacoes = await Api.MinhasDoacoesAsync();
        }
        catch
        {
            _erro = true;
        }
        finally
        {
            _carregando = false;
        }
    }

    private static string FormatMoeda(decimal valor) => valor.ToString("C", Br);

    private static string FormatData(DateTimeOffset data) => data.ToLocalTime().ToString("dd/MM/yyyy HH:mm", Br);

    private static Color StatusCor(string status) => status switch
    {
        "Pendente" => Color.Warning,
        "Processada" => Color.Success,
        "Rejeitada" => Color.Error,
        "Falha" => Color.Default,
        _ => Color.Default,
    };

    private static string StatusRotulo(string status) => status switch
    {
        "Processada" => "Processada",
        _ => status,
    };
}
