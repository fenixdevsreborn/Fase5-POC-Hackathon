@page "/doador"
@inject NavigationManager Nav

<PageTitle>Meu painel</PageTitle>

<AuthorizeView Roles="Doador">
    <Authorized>
        <header class="donor-hero" data-reveal>
            <div class="donor-hero__content">
                <span class="donor-hero__badge">
                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" />
                    Área segura do doador
                </span>
                <h1>Olá, <span>@(context.User.Identity?.Name ?? "doador")</span>!</h1>
                <p>
                    Cada contribuição começa uma história. Descubra novas causas e acompanhe o impacto das suas doações com transparência.
                </p>
                <div class="donor-hero__actions">
                    <a class="donor-button donor-button--primary" href="/campanhas">
                        <MudIcon Icon="@Icons.Material.Filled.FavoriteBorder" Size="Size.Small" />
                        Encontrar uma causa
                    </a>
                    <a class="donor-button donor-button--ghost" href="/doador/doacoes">
                        Ver minhas doações
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                    </a>
                </div>
                <div class="donor-hero__trust">
                    <span><MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" /> Ambiente protegido</span>
                    <span><MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" /> Atualização em tempo real</span>
                </div>
            </div>
            <div class="donor-hero__visual" aria-hidden="true">
                <img src="images/campanhas/web/medium-shot-volunteers-with-donations.jpg" alt="" />
                <span class="donor-hero__impact-card">
                    <i><MudIcon Icon="@Icons.Material.Filled.VolunteerActivism" /></i>
                    <span><strong>Impacto real</strong><small>Contribuições que chegam a quem precisa</small></span>
                </span>
            </div>
        </header>

        <div class="cs-section-heading" data-reveal>
            <div><span class="cs-kicker">Atalhos do seu painel</span><h2>Tudo o que você precisa, em um só lugar</h2></div>
            <p>Acompanhe uma contribuição existente ou explore campanhas verificadas pela plataforma.</p>
        </div>

        <section class="donor-action-grid" aria-label="Ações do doador">
            <article class="cs-feature-card donor-action-card" data-reveal>
                <span class="cs-icon-orb"><MudIcon Icon="@Icons.Material.Filled.Explore" /></span>
                <h2>Descubra novas campanhas</h2>
                <p>Explore histórias, conheça metas e escolha com clareza onde sua ajuda fará diferença.</p>
                <div class="donor-action-card__links">
                    <a class="cs-action-link" href="/campanhas">Explorar campanhas <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" /></a>
                    <a class="donor-text-link" href="/transparencia">Ver transparência</a>
                </div>
            </article>

            <article class="cs-feature-card donor-action-card donor-action-card--track" data-reveal>
                <span class="cs-icon-orb cs-icon-orb--orange"><MudIcon Icon="@Icons.Material.Filled.TrackChanges" /></span>
                <h2>Acompanhe por protocolo</h2>
                <p>Informe o identificador recebido após a doação para consultar o processamento.</p>
                <div class="donor-protocol">
                    <MudTextField T="string" @bind-Value="_protocolo"
                                  Label="ID da doação"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.ArrowForward"
                                  OnAdornmentClick="Acompanhar"
                                  Error="_protocoloInvalido"
                                  ErrorText="Informe um ID válido."
                                  Immediate="true" />
                    <MudButton OnClick="Acompanhar" Variant="Variant.Filled" Color="Color.Primary">
                        Consultar status
                    </MudButton>
                </div>
            </article>
        </section>

        <section class="donor-process" data-reveal aria-labelledby="process-title">
            <div class="donor-process__intro">
                <span class="cs-kicker">Transparência em cada etapa</span>
                <h2 id="process-title">Da contribuição ao impacto</h2>
                <p>O processamento é assíncrono, seguro e acompanhado em tempo real. Você pode voltar quando quiser usando o protocolo.</p>
            </div>
            <ol class="donor-process__steps">
                <li><span>01</span><div><strong>Recebida</strong><small>Seu pedido entra na fila segura.</small></div></li>
                <li><span>02</span><div><strong>Validada</strong><small>Os dados são conciliados.</small></div></li>
                <li><span>03</span><div><strong>Processada</strong><small>A campanha recebe a contribuição.</small></div></li>
            </ol>
        </section>
    </Authorized>
    <NotAuthorized>
        <section class="cs-access-state"><div>
            <span class="cs-access-state__icon"><MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" /></span>
            <h1>Seu painel está protegido</h1>
            <p>Entre com sua conta de doador para acompanhar contribuições e apoiar novas causas.</p>
            <MudButton Href="/entrar?returnUrl=%2Fdoador" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Login">Entrar</MudButton>
        </div></section>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string _protocolo = string.Empty;
    private bool _protocoloInvalido;

    private void Acompanhar()
    {
        if (Guid.TryParse(_protocolo?.Trim(), out var id))
        {
            _protocoloInvalido = false;
            Nav.NavigateTo($"/doador/doacoes/{id}");
        }
        else
        {
            _protocoloInvalido = true;
        }
    }
}
