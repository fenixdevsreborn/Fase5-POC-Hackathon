<div class="cs-empty-state">
    <div>
    <span class="cs-empty-state__icon"><MudIcon Icon="@Icon" Size="Size.Large" /></span>
    <h2>@Title</h2>
    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <p>@Description</p>
    }
    @if (ChildContent is not null)
    {
        <div class="cs-empty-state__actions">
            @ChildContent
        </div>
    }
    </div>
</div>

@code {
    /// <summary>Icone Material exibido no topo. Padrao: caixa vazia.</summary>
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Inbox;

    /// <summary>Titulo curto do estado vazio.</summary>
    [Parameter] public string Title { get; set; } = "Nada por aqui";

    /// <summary>Mensagem opcional de apoio.</summary>
    [Parameter] public string? Description { get; set; }

    /// <summary>Conteudo opcional (ex.: botao de acao / tentar novamente).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
