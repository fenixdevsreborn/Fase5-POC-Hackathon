@* Esqueleto de carregamento em grade, imitando os CampaignCard. *@
<div class="cs-skeleton-grid" aria-label="Carregando conteúdo" aria-busy="true">
    @for (var i = 0; i < Count; i++)
    {
        <div class="cs-skeleton-card">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="145px" />
            <div class="cs-skeleton-card__body">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="70%" Height="30px" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="100%" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="85%" Class="mb-4" />
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="10px" Class="my-2" />
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="100%" Height="40px" Class="mt-3" />
            </div>
        </div>
    }
</div>

@code {
    /// <summary>Quantidade de cartoes-fantasma exibidos (padrao 3).</summary>
    [Parameter] public int Count { get; set; } = 3;
}
